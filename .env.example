# Dokploy API
DOKPLOY_BASE_URL=https://dokploy.example.com
DOKPLOY_API_KEY=replace_me

# Coordinator target: existing Dagster project
DOKPLOY_COORDINATOR_PROJECT_NAME=Dagster
DOKPLOY_COORDINATOR_ENVIRONMENT_NAME=production
DOKPLOY_COORDINATOR_ENVIRONMENT_ID=replace_me
DOKPLOY_COORDINATOR_SERVER_ID=replace_me
DOKPLOY_COORDINATOR_COMPOSE_NAME=dispatch-coordinator

# Worker target: separate Dispatch-style project on the findash server
DOKPLOY_WORKER_PROJECT_NAME=Dokploy-dispatch
DOKPLOY_WORKER_ENVIRONMENT_NAME=production
DOKPLOY_WORKER_ENVIRONMENT_ID=replace_me
DOKPLOY_WORKER_SERVER_ID=replace_me
DOKPLOY_WORKER_COMPOSE_NAME=dispatch-worker

# Runtime values
DISPATCH_COORDINATOR_URL=http://10.0.0.12:4000
COORDINATOR_BIND_IP=10.0.0.12
DISPATCH_WORKER_CONCURRENCY=5
DISPATCH_WORKER_POLL_INTERVAL_MS=1000
DISPATCH_WORKER_NAME=worker-server-1
DISPATCH_WORKER_PYTHON_BIN=/opt/dispatch-python/bin/python

# Optional worker package install for project-specific Python callables.
# Example for a repo with a Python package in a subdirectory:
# PYTHON_PACKAGE_SPEC=git+https://github.com/example/project.git#subdirectory=python_package
PYTHON_PACKAGE_SPEC=

# JSON object mapping HTTP-safe aliases to Python module:function targets.
# Example:
# DISPATCH_CALLABLE_ALLOWLIST_JSON={"example_job":"my_project.jobs:run_example_job"}
DISPATCH_CALLABLE_ALLOWLIST_JSON={}

# Example runtime env needed by a project-specific callable.
FMP_API_KEY=
API_KEY=
BUCKET_NAME=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=
AWS_DEFAULT_REGION=

# Git source used by Dokploy compose services
DOKPLOY_GIT_SOURCE_TYPE=git
DOKPLOY_GIT_URL=https://github.com/Abdulrahman-97/dispatch.git
DOKPLOY_GIT_BRANCH=main
